{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Proxy Hopper",
  "colors": {
    "primary": "#0D9488",
    "light": "#14B8A6",
    "dark": "#0F766E"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "height": 60
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/cams-data/proxy-hopper-v2"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Releases",
      "href": "https://github.com/cams-data/proxy-hopper-v2/releases"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction",
              "quickstart",
              "integration-modes"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/reference",
              "configuration/proxy-providers",
              "configuration/ip-pools",
              "configuration/targets",
              "configuration/server"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/docker",
              "deployment/kubernetes"
            ]
          },
          {
            "group": "Backends",
            "pages": [
              "backends/memory",
              "backends/redis"
            ]
          },
          {
            "group": "Observability",
            "pages": [
              "observability/metrics",
              "observability/logging"
            ]
          },
          {
            "group": "Development",
            "pages": [
              "development/architecture",
              "development/testing"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/cams-data/proxy-hopper-v2",
          "icon": "github"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/cams-data/proxy-hopper-v2/releases",
          "icon": "tag"
        }
      ]
    }
  },
  "styling": {
    "codeblocks": {
      "themes": {
        "light": "github-light",
        "dark": "catppuccin-mocha"
      }
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cams-data/proxy-hopper-v2"
    }
  }
}
