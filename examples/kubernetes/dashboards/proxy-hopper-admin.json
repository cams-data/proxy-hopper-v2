{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Proxy Hopper — Administrator view. Pool health, IP quarantine, retry pressure, queue depth, and alert signals.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pool Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Fraction of IPs currently available (not quarantined). Drop below 50% warrants attention; below 20% is critical.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "IP Availability Ratio",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target) (proxy_hopper_available_ips{target=~\"$target\"}) / (sum by (target) (proxy_hopper_available_ips{target=~\"$target\"}) + sum by (target) (proxy_hopper_quarantined_ips{target=~\"$target\"}))",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "IPs available vs quarantined over time per target.",
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 10, "x": 4, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Available vs Quarantined IPs",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "proxy_hopper_available_ips{target=~\"$target\"}",
          "legendFormat": "available — {{target}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "proxy_hopper_quarantined_ips{target=~\"$target\"}",
          "legendFormat": "quarantined — {{target}}",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of quarantine events per minute. A rising rate means upstream APIs are degrading or IP quality is declining.",
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 10, "x": 14, "y": 1 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Quarantine Event Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_ip_quarantine_events_total{target=~\"$target\"}[5m]) * 60",
          "legendFormat": "{{target}} — {{address}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current consecutive failure count for each IP. IPs approaching ip_failures_until_quarantine threshold are at risk.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "displayMode": "color-background" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "id": 4,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Failures", "desc": true }] },
      "title": "IP Failure Counts (current)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "proxy_hopper_ip_failure_count{target=~\"$target\"} > 0",
          "legendFormat": "{{target}} — {{address}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "target": "Target", "address": "Address", "Value": "Failures" }, "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ],
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 101,
      "title": "Request Throughput & Error Rates",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total request rate through proxy-hopper per target.",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 13 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target) (rate(proxy_hopper_requests_total{target=~\"$target\"}[1m]))",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Fraction of requests that resulted in a non-success outcome (rate_limited, server_error, connection_error). Does not include retried requests that eventually succeeded.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 13 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Outbound Error Rate (by outcome)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target) (rate(proxy_hopper_requests_total{target=~\"$target\", outcome!=\"success\"}[5m])) / sum by (target) (rate(proxy_hopper_requests_total{target=~\"$target\"}[5m]))",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "HTTP status codes returned to clients per target. Distinguishes 429/502/503/504 at the dashboard level.",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 13 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Response Status Code Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target, status_code) (rate(proxy_hopper_responses_total{target=~\"$target\"}[1m]))",
          "legendFormat": "{{target}} {{status_code}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "Retry Pressure",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of retry attempts per minute. High values indicate upstream instability — requests are failing their first attempt and being re-queued.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Retry Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_retries_total{target=~\"$target\"}[1m]) * 60",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of requests that exhausted all retries and returned an error to the client. This is a direct SLO breach signal.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Retry Exhaustion Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_retry_exhaustions_total{target=~\"$target\"}[5m]) * 60",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Ratio of retried requests to total outbound attempts. Above 10% suggests significant upstream instability.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.3 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Retry Ratio",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target) (rate(proxy_hopper_retries_total{target=~\"$target\"}[5m])) / sum by (target) (rate(proxy_hopper_requests_total{target=~\"$target\"}[5m]))",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 103,
      "title": "Queue Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Number of requests currently waiting for an available IP. Sustained depth > 0 means the pool is undersized for the load.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 27 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Queue Depth",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "proxy_hopper_queue_depth{target=~\"$target\"}",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Queue wait time percentiles — time from request arrival to IP dispatch. P95 above 1s suggests pool contention.",
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 27 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Queue Wait Time (P50/P95/P99)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (target, le) (rate(proxy_hopper_queue_wait_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P50 — {{target}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (target, le) (rate(proxy_hopper_queue_wait_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P95 — {{target}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (target, le) (rate(proxy_hopper_queue_wait_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P99 — {{target}}",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of requests dropped because they waited longer than max_queue_wait for an IP. Any non-zero value means clients are receiving 503s due to pool exhaustion.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 27 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Queue Expiry Rate (→ 503)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_queue_expired_total{target=~\"$target\"}[5m]) * 60",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "title": "Infrastructure",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Active client connections to proxy-hopper. With keep-alive, this reflects the number of open sessions rather than request rate.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 34 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Active Client Connections",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(proxy_hopper_active_connections)",
          "legendFormat": "connections",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Background IP probe success/failure rates per address. Failures here do not affect the pool — they are observability only.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 34 },
      "id": 15,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Probe Success / Failure Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_probe_success_total[5m]) * 60",
          "legendFormat": "success — {{address}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_probe_failure_total[5m]) * 60",
          "legendFormat": "fail ({{reason}}) — {{address}}",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current reachability state per IP address from the background prober. 1 = reachable, 0 = unreachable.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 34 },
      "id": 16,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "IP Reachability (Probe)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "proxy_hopper_ip_reachable",
          "legendFormat": "{{address}}",
          "refId": "A"
        }
      ],
      "type": "stat"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "tags": ["proxy-hopper", "admin"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "label": "datasource",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(proxy_hopper_requests_total, target)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "target",
        "options": [],
        "query": {
          "query": "label_values(proxy_hopper_requests_total, target)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Target"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Proxy Hopper — Admin",
  "uid": "proxy-hopper-admin",
  "version": 1
}
