{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Proxy Hopper — User view. Request latency, success rates, outcome breakdown, and active connections per target.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current request rate across all selected targets.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Request Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(proxy_hopper_requests_total{target=~\"$target\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Fraction of requests that completed successfully (outcome=success) over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.98 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Success Rate",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(proxy_hopper_requests_total{target=~\"$target\", outcome=\"success\"}[5m])) / sum(rate(proxy_hopper_requests_total{target=~\"$target\"}[5m]))",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Median (P50) end-to-end request duration for outbound proxy requests over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1.0 },
              { "color": "red", "value": 5.0 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Latency P50",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(proxy_hopper_request_duration_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "95th percentile end-to-end request duration over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3.0 },
              { "color": "red", "value": 10.0 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Latency P95",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(proxy_hopper_request_duration_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Number of open client connections to proxy-hopper. With keep-alive this reflects persistent sessions, not request rate.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Active Connections",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(proxy_hopper_active_connections)",
          "legendFormat": "connections",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of retried requests. Non-zero means some first-attempt failures are being recovered transparently.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Retry Rate (per min)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(proxy_hopper_retries_total{target=~\"$target\"}[1m])) * 60",
          "legendFormat": "retries/min",
          "refId": "A"
        }
      ],
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "P50/P95/P99 of outbound request duration per target. This is the end-to-end time from proxy-hopper sending the request to receiving the full response body.",
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Duration P50 / P95 / P99",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (target, le) (rate(proxy_hopper_request_duration_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P50 — {{target}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (target, le) (rate(proxy_hopper_request_duration_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P95 — {{target}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (target, le) (rate(proxy_hopper_request_duration_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P99 — {{target}}",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "P50/P95/P99 of time spent waiting in the queue before an IP was assigned. Compare with request duration to distinguish 'slow queue' from 'slow upstream'.",
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Queue Wait Time P50 / P95 / P99",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (target, le) (rate(proxy_hopper_queue_wait_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P50 — {{target}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (target, le) (rate(proxy_hopper_queue_wait_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P95 — {{target}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (target, le) (rate(proxy_hopper_queue_wait_seconds_bucket{target=~\"$target\"}[5m])))",
          "legendFormat": "P99 — {{target}}",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 102,
      "title": "Request Outcomes",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Request success rate over time per target. Drops here mean clients are receiving errors.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Success Rate Over Time",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target) (rate(proxy_hopper_requests_total{target=~\"$target\", outcome=\"success\"}[5m])) / sum by (target) (rate(proxy_hopper_requests_total{target=~\"$target\"}[5m]))",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Breakdown of HTTP status codes returned to clients. Helps distinguish 429 rate-limiting from 502/503/504 infrastructure errors.",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Response Status Codes Returned to Client",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target, status_code) (rate(proxy_hopper_responses_total{target=~\"$target\"}[1m]))",
          "legendFormat": "{{target}} HTTP {{status_code}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Proportion of each outcome type over the selected time window. A healthy system should be almost entirely 'success'.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 21 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
        "tooltip": { "mode": "single" }
      },
      "title": "Outcome Distribution",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (outcome) (increase(proxy_hopper_requests_total{target=~\"$target\"}[$__range]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "type": "piechart"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Retry attempts over time — each bar is a request that failed its first attempt and was re-queued. Transparent to the client if it eventually succeeds.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 21 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Retry Attempts Over Time",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_retries_total{target=~\"$target\"}[1m]) * 60",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Retry exhaustions — requests where all retries failed and an error was returned to the client. These are visible failures. Any sustained non-zero rate warrants investigation.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 21 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Retry Exhaustions (Client-Visible Errors)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(proxy_hopper_retry_exhaustions_total{target=~\"$target\"}[5m]) * 60",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total number of requests processed per target over the selected time window, broken down by outcome. Uses increase() over each step interval so the y-axis shows actual request counts rather than a rate.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 28 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Count Over Time",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (target, outcome) (increase(proxy_hopper_requests_total{target=~\"$target\"}[$__interval]))",
          "legendFormat": "{{target}} — {{outcome}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "tags": ["proxy-hopper", "user"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "label": "datasource",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(proxy_hopper_requests_total, target)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "target",
        "options": [],
        "query": {
          "query": "label_values(proxy_hopper_requests_total, target)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Target"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Proxy Hopper — User",
  "uid": "proxy-hopper-user",
  "version": 1
}
